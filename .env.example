# ─────────────────────────────────────────────────────
#  Email Hunter SMTP Pro — variáveis de ambiente
# ─────────────────────────────────────────────────────

# Porta (Render/Railway definem automaticamente via PORT)
PORT=3000

# Domínio usado no EHLO do SMTP (coloque o domínio do seu servidor)
# Quanto mais legítimo, menor chance de bloqueio
HELO_DOMAIN=mail.seudominio.com.br

# E-mail remetente usado no MAIL FROM (não precisa existir)
FROM_EMAIL=verify@seudominio.com.br

# Quantas conexões SMTP simultâneas
# - VPS com IP limpo: até 5
# - IP residencial/compartilhado: 2-3 para evitar bloqueios
SMTP_CONCURRENCY=3

# CORS — coloque a URL do seu frontend em produção
CORS_ORIGIN=*
